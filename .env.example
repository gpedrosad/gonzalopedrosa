# Copia a .env.local y completa los valores

# Google Search Console — OAuth (recomendado; la cuenta de servicio a veces no se puede añadir en GSC)
GSC_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_PATH=.secrets/gcp-oauth-client.json
# Usa la URL exacta que ves en GSC (dominio o prefijo www)
GSC_SITE_URL=sc-domain:gonzalopedrosa.cl

# Alternativa: cuenta de servicio (si Google permite añadir el email en GSC)
# GSC_AUTH_MODE=service_account
# GOOGLE_APPLICATION_CREDENTIALS=.secrets/gcp-service-account.json

# Panel interno /interno/gsc (opcional: ?key= en la URL)
# GSC_DASHBOARD_SECRET=tu-clave-secreta-larga
# GSC_DASHBOARD_DAYS=28
